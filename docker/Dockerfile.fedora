FROM fedora:latest AS build

RUN dnf -y install \
    ca-certificates \
    curl \
    gcc \
    libcurl-devel \
    make \
    openssl-devel \
    pkgconf-pkg-config \
    && dnf clean all

WORKDIR /src
COPY . .
RUN make -j"$(nproc)"

FROM fedora:latest

RUN dnf -y install \
    ca-certificates \
    curl \
    libcurl \
    openssl-libs \
    && dnf clean all

WORKDIR /workspace
COPY --from=build /src/warp /usr/local/bin/warp

ENTRYPOINT ["/usr/local/bin/warp"]
CMD ["--help"]
